#!/usr/bin/env bash
# ==============================================================================
# 服务器环境初始化脚本（模板版）
# 适用系统: Ubuntu 22.04 / 24.04
# 用法: sudo bash init.sh
# 注意: 以下 占位符由 Python 脚本在上传前替换为实际值
# ==============================================================================

set -euo pipefail

# ============================================================
# 全局变量配置（由 Python 脚本渲染后填入）
# ============================================================
SOURCE_SERVER="root@{{ source_server_ip }}"
SYNC_FROM_SOURCE={{ 'true' if sync_from_source else 'false' }}
HOSTNAME_NEW="{{ hostname }}"
SWAP_FILE="/mnt/swapfile"
SWAP_SIZE_MB={{ swap_size_mb }}
SOFTWARE_DIR="/opt/software"
FRP_VERSION="0.67.0"
FRP_ARCH="linux_amd64"
FRP_DIR_NAME="frp_${FRP_VERSION}_${FRP_ARCH}"
FRP_INSTALL_DIR="${SOFTWARE_DIR}/${FRP_DIR_NAME}"
ACME_HOME="${SOFTWARE_DIR}/acmesh"
ACME_EMAIL="{{ acme_email }}"
CF_Token="{{ cf_token }}"
CF_Account_ID="{{ cf_account_id }}"
CERT_DOMAIN="{{ cert_domain }}"
CERT_DIR="/usr/local/openresty/nginx/certs"

# ============================================================
# 日志颜色
# ============================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${GREEN}[INFO]${NC}  $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
log_section() { echo -e "\n${BLUE}========== $* ==========${NC}"; }

run_or_warn() {
    if ! "$@"; then
        log_warn "命令执行失败 (非关键，继续执行): $*"
    fi
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "此脚本需要 root 权限，请使用 sudo 运行"
        exit 1
    fi
}

# ============================================================
# 1. 同步登录凭据
# ============================================================
setup_ssh_keys() {
    log_section "1. 同步登录凭据"
{% if sync_from_source %}
    if [[ ! -f "$HOME/.ssh/id_rsa" && ! -f "$HOME/.ssh/id_ed25519" ]]; then
        log_info "生成 SSH 密钥对..."
        ssh-keygen -t ed25519 -N "" -f "$HOME/.ssh/id_ed25519"
    else
        log_info "SSH 密钥已存在，跳过生成"
    fi

    log_info "将本机公钥复制到源服务器 ${SOURCE_SERVER}..."
    ssh-copy-id -o StrictHostKeyChecking=no "${SOURCE_SERVER}"

    log_info "将源服务器加入本机 known_hosts..."
    ssh-keyscan "$(echo "${SOURCE_SERVER}" | cut -d@ -f2)" >> "$HOME/.ssh/known_hosts" 2>/dev/null || true
{% else %}
    log_info "sync_from_source=false，跳过源服务器凭据同步"
{% endif %}
}

# ============================================================
# 2. 去除阿里云内置监控控件 (cloudmonitor)
# ============================================================
remove_aliyun_cloudmonitor() {
    log_section "2. 去除阿里云内置监控控件 (cloudmonitor)"

    local ctl="/usr/local/cloudmonitor/cloudmonitorCtl.sh"

    if ps aux | grep -q '[a]rgusagent'; then
        log_info "检测到 argusagent 进程，开始卸载..."
        if [[ -f "$ctl" ]]; then
            run_or_warn bash "$ctl" stop
            run_or_warn bash "$ctl" uninstall
        fi
        run_or_warn rm -rf /usr/local/cloudmonitor
        log_info "cloudmonitor 卸载完成"
    else
        log_info "未检测到 cloudmonitor，跳过"
    fi
}

# ============================================================
# 3. 去除阿里云内置安全控件 (aegis)
# ============================================================
remove_aliyun_aegis() {
    log_section "3. 去除阿里云内置安全控件 (aegis)"

    if ! ps -ef | grep -qE 'AliYunDun|YunDunMonitor|YunDunUpdate'; then
        log_info "未检测到阿里云安全控件，跳过"
        return
    fi

    log_info "检测到阿里云安全进程，开始卸载..."
    log_warn "aegis 可能开启了自保护 —— 若卸载失败，请先在阿里云控制台 [安全中心] 关闭自保护后重试"
    for proc in AliYunDun AliYunDunUpdate AliYunDunMonitor argusagent; do
        pkill -9 -f "$proc" 2>/dev/null || true
    done
    sleep 2

    local tmp_uninstall
    tmp_uninstall=$(mktemp /tmp/aegis_uninstall.XXXXXX.sh)
    if wget -q "http://update2.aegis.aliyun.com/download/uninstall.sh" -O "$tmp_uninstall"; then
        chmod +x "$tmp_uninstall"
        run_or_warn bash "$tmp_uninstall"
        rm -f "$tmp_uninstall"
    else
        log_warn "下载 aegis 卸载脚本失败，尝试手动清理目录..."
        run_or_warn rm -rf /usr/local/aegis
    fi

    run_or_warn rm -rf /usr/local/aegis /etc/init.d/aegis
    log_info "aegis 卸载流程完成"
}

# ============================================================
# 4. 去除阿里云云助手控件
# ============================================================
remove_aliyun_assist() {
    log_section "4. 去除阿里云云助手控件"

    local assist_daemon="/usr/local/share/assist-daemon/assist_daemon"

    if [[ -f "$assist_daemon" ]]; then
        log_info "停止云助手守护进程..."
        run_or_warn "$assist_daemon" --stop
    fi

    if systemctl is-active --quiet aliyun.service 2>/dev/null; then
        log_info "停止 aliyun.service..."
        run_or_warn systemctl stop aliyun.service
        run_or_warn systemctl disable aliyun.service
    else
        log_info "aliyun.service 未运行，跳过"
    fi
}

# ============================================================
# 5. 优化日志存储
# ============================================================
optimize_journal() {
    log_section "5. 优化日志存储 (systemd-journald)"

    local conf="/etc/systemd/journald.conf"

    declare -A journal_settings=(
        [SystemMaxUse]="500M"
        [SystemMaxFileSize]="100M"
        [MaxRetentionSec]="1month"
    )

    for key in "${!journal_settings[@]}"; do
        local value="${journal_settings[$key]}"
        if grep -q "^#*\s*${key}=" "$conf"; then
            sed -i "s|^#*\s*${key}=.*|${key}=${value}|" "$conf"
        else
            echo "${key}=${value}" >> "$conf"
        fi
    done

    systemctl restart systemd-journald
    log_info "journald 配置已更新并重启"
}

# ============================================================
# 6. 增加 Swap
# ============================================================
setup_swap() {
    log_section "6. 增加 Swap (${SWAP_SIZE_MB}M)"

    if swapon --show | grep -q "${SWAP_FILE}"; then
        log_info "Swap 文件 ${SWAP_FILE} 已存在，跳过"
        return
    fi

    log_info "创建 swap 文件 ${SWAP_FILE} (${SWAP_SIZE_MB}M)..."
    dd if=/dev/zero of="${SWAP_FILE}" bs=1M count="${SWAP_SIZE_MB}" status=progress
    chmod 600 "${SWAP_FILE}"
    mkswap "${SWAP_FILE}"
    swapon "${SWAP_FILE}"

    if ! grep -q "${SWAP_FILE}" /etc/fstab; then
        echo "${SWAP_FILE} none swap sw 0 0" >> /etc/fstab
    fi

    sysctl -w vm.swappiness=60 > /dev/null
    sysctl -w vm.vfs_cache_pressure=50 > /dev/null

    local sysctl_conf="/etc/sysctl.conf"
    grep -q "^vm.swappiness" "$sysctl_conf" \
        && sed -i 's/^vm.swappiness.*/vm.swappiness=60/' "$sysctl_conf" \
        || echo "vm.swappiness=60" >> "$sysctl_conf"
    grep -q "^vm.vfs_cache_pressure" "$sysctl_conf" \
        && sed -i 's/^vm.vfs_cache_pressure.*/vm.vfs_cache_pressure=50/' "$sysctl_conf" \
        || echo "vm.vfs_cache_pressure=50" >> "$sysctl_conf"

    sysctl -p > /dev/null
    log_info "Swap 已启用:"
    swapon --show
}

# ============================================================
# 7. 修改主机名
# ============================================================
set_hostname() {
    log_section "7. 修改主机名为 ${HOSTNAME_NEW}"

    local current
    current=$(hostname)
    if [[ "$current" == "$HOSTNAME_NEW" ]]; then
        log_info "主机名已是 ${HOSTNAME_NEW}，跳过"
        return
    fi

    hostnamectl set-hostname "${HOSTNAME_NEW}"
    log_info "主机名已修改为: $(hostname)"
}

# ============================================================
# 8.1 安装基础软件包
# ============================================================
install_base_packages() {
    log_section "8.1 安装基础软件包"
    apt-get update -q
    apt-get install -y --no-install-recommends \
        curl wget git rsync vim htop net-tools \
        ca-certificates gnupg lsb-release
    log_info "基础软件包安装完成"
}

# ============================================================
# 8.2 安装 sing-box
# ============================================================
install_singbox() {
    log_section "8.2 安装 sing-box"

    if command -v sing-box &>/dev/null; then
        log_info "sing-box 已安装，跳过"
    else
        log_info "配置 sing-box 官方仓库..."
        mkdir -p /etc/apt/keyrings
        curl -fsSL https://sing-box.app/gpg.key -o /etc/apt/keyrings/sagernet.asc
        chmod a+r /etc/apt/keyrings/sagernet.asc

        cat > /etc/apt/sources.list.d/sagernet.sources <<'EOF'
Types: deb
URIs: https://deb.sagernet.org/
Suites: *
Components: *
Enabled: yes
Signed-By: /etc/apt/keyrings/sagernet.asc
EOF

        apt-get update -q
        apt-get install -y sing-box
        log_info "sing-box 安装完成"
    fi

    log_info "同步 sing-box 配置..."
{% if sync_from_source %}
    rsync -avzP -e "ssh -o StrictHostKeyChecking=no" \
        "${SOURCE_SERVER}:/etc/sing-box/config.json" /etc/sing-box/config.json
{% else %}
    log_info "sync_from_source=false，sing-box 配置已由 Python 脚本直接上传，跳过 rsync"
{% endif %}

    systemctl enable --now sing-box
    log_info "sing-box 已启动并设为开机自启"
}

# ============================================================
# 8.3 安装 OpenResty
# ============================================================
install_openresty() {
    log_section "8.3 安装 OpenResty"

    if command -v openresty &>/dev/null; then
        log_info "OpenResty 已安装，跳过"
    else
        log_info "安装依赖..."
        apt-get install -y --no-install-recommends wget gnupg ca-certificates lsb-release

        log_info "导入 OpenResty GPG 公钥..."
        wget -qO - https://openresty.org/package/pubkey.gpg \
            | gpg --dearmor -o /usr/share/keyrings/openresty.gpg

        log_info "添加 OpenResty 仓库..."
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/openresty.gpg] \
http://openresty.org/package/ubuntu $(lsb_release -sc) main" \
            | tee /etc/apt/sources.list.d/openresty.list > /dev/null

        apt-get update -q
        apt-get install -y openresty
        log_info "OpenResty 安装完成"
    fi

    log_info "同步 nginx 配置及静态文件..."
{% if sync_from_source %}
    rsync -avzP -e "ssh -o StrictHostKeyChecking=no" \
        "${SOURCE_SERVER}:/usr/local/openresty/nginx/conf/nginx.conf" \
        /usr/local/openresty/nginx/conf/nginx.conf
    rsync -avzP -e "ssh -o StrictHostKeyChecking=no" \
        "${SOURCE_SERVER}:/usr/local/openresty/nginx/conf/conf.d" \
        /usr/local/openresty/nginx/conf/
    rsync -avzP -e "ssh -o StrictHostKeyChecking=no" \
        "${SOURCE_SERVER}:/usr/local/openresty/nginx/html/" \
        /usr/local/openresty/nginx/html/
{% else %}
    log_info "sync_from_source=false，跳过 nginx 配置同步"
{% endif %}

    mkdir -p "${CERT_DIR}"
    log_info "证书目录已创建: ${CERT_DIR}"

    systemctl enable --now openresty
    log_info "OpenResty 已启动"
}

# ============================================================
# 8.4 安装 acme.sh 并签发证书
# ============================================================
install_acmesh() {
    log_section "8.4 安装 acme.sh 并签发证书"

    local acme_bin="${ACME_HOME}/acme.sh"

    if [[ -f "$acme_bin" ]]; then
        log_info "acme.sh 已安装于 ${ACME_HOME}，跳过安装"
    else
        log_info "克隆 acme.sh..."
        rm -rf /tmp/acme.sh_src
        git clone --depth 1 https://github.com/acmesh-official/acme.sh.git /tmp/acme.sh_src
        chmod 755 /tmp/acme.sh_src/acme.sh
        ( cd /tmp/acme.sh_src && ./acme.sh --install -m "${ACME_EMAIL}" --home "${ACME_HOME}" )
        rm -rf /tmp/acme.sh_src
        log_info "acme.sh 已安装到 ${ACME_HOME}"
    fi

    local bashrc_entry=". \"${ACME_HOME}/acme.sh.env\""
    if ! grep -qF "$bashrc_entry" "$HOME/.bashrc"; then
        echo "$bashrc_entry" >> "$HOME/.bashrc"
    fi

    export CF_Token
    export CF_Account_ID

    log_info "设置默认 CA 为 Let's Encrypt..."
    "$acme_bin" --set-default-ca --server letsencrypt

    log_info "注册 acme.sh 账号..."
    "$acme_bin" --register-account -m "${ACME_EMAIL}" || true

    log_info "申请证书: ${CERT_DOMAIN}..."
    # acme.sh 退出码说明:
    #   0  — 申请成功
    #   2  — 域名未变更 / 证书已存在且未到期（跳过，不算错误）
    #   其他 — 真正的失败
    local _issue_rc=0
    "$acme_bin" --issue --dns dns_cf -d "${CERT_DOMAIN}" || _issue_rc=$?
    if [[ $_issue_rc -eq 0 ]]; then
        log_info "证书申请成功"
    elif [[ $_issue_rc -eq 2 ]]; then
        log_info "证书未变更（已存在且未到期），跳过申请"
    else
        log_error "证书申请失败 (exit ${_issue_rc})"
        return "${_issue_rc}"
    fi

    log_info "安装证书到 OpenResty..."
    mkdir -p "${CERT_DIR}"
    local _install_rc=0
    "$acme_bin" --install-cert -d "${CERT_DOMAIN}" \
        --cert-file      "${CERT_DIR}/${CERT_DOMAIN}.cert.pem" \
        --key-file       "${CERT_DIR}/${CERT_DOMAIN}.key.pem" \
        --fullchain-file "${CERT_DIR}/${CERT_DOMAIN}.fullchain.pem" \
        --reloadcmd      "systemctl restart sing-box; systemctl restart openresty" \
        || _install_rc=$?
    if [[ $_install_rc -ne 0 ]]; then
        log_warn "安装证书返回非零退出码 ${_install_rc}（证书可能已就位，继续执行）"
    fi

    log_info "证书已安装到 ${CERT_DIR}"
}

# ============================================================
# 主流程
# ============================================================
main() {
    log_section "服务器环境初始化开始"
    check_root

    setup_ssh_keys
    remove_aliyun_cloudmonitor
    remove_aliyun_aegis
    remove_aliyun_assist
    optimize_journal
    setup_swap
    set_hostname

    install_base_packages
    install_singbox
    install_openresty
    install_acmesh

    log_section "初始化全部完成 ✓"
    log_info "建议执行: source ~/.bashrc 使环境变量生效"
}

main "$@"
