# =============================================================================
# 云服务商访问凭证 (首期支持阿里云 SWAS / BSS API)
# =============================================================================
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# =============================================================================
# DNS 服务商访问凭证 (首期支持 Cloudflare)
# =============================================================================
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_cloudflare_zone_id
CF_ACCOUNT_ID=your_cloudflare_account_id

# =============================================================================
# 服务器 SSH 登录密码 (用于 API 重置密码与后续部署，初始化命令 init 必须)
# 要求：8~30 位，须同时包含大小写字母和数字，可含特殊字符
# =============================================================================
SERVER_SSH_PASSWORD=Your$tr0ngP@ssword

# =============================================================================
# 自动化轮转源 ID (轮转命令 rotate 必须，也可以在 config.yaml 或命令行参数中指定)
# =============================================================================
RESOURCE_ID=your_instance_id_or_image_id
